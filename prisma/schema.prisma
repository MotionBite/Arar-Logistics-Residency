generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String?
  email        String?  @unique
  phone        String?
  nationality  String?
  role         Role     @default(USER)
  passwordHash String?
  googleId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings      Booking[]
  reviews       Review[]
  notifications Notification[]
  favorites     FavoriteRoom[]
}

enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────────
// ROOM
// ─────────────────────────────────────────────

model Room {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  slug           String   @unique
  nameAr         String
  nameEn         String
  descAr         String
  descEn         String
  type           RoomType
  capacity       Int
  bedCount       Int      @default(1)
  bathroomCount  Int      @default(1)
  floorNumber    Int
  priceNightly   Float
  priceWeekly    Float
  priceMonthly   Float
  discountPct    Float    @default(0)
  amenities      String[]
  isAvailable    Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  images    RoomImage[]
  bookings  Booking[]
  reviews   Review[]
  favorites FavoriteRoom[]
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  FAMILY
}

model RoomImage {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  roomId    String  @db.ObjectId
  url       String
  publicId  String
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  userId          String        @db.ObjectId
  roomId          String        @db.ObjectId
  checkIn         DateTime
  checkOut        DateTime
  bookingType     BookingType
  guests          Int
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  totalPrice      Float
  couponId        String?       @db.ObjectId
  specialRequests String?
  paymentIntentId String?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  room   Room    @relation(fields: [roomId], references: [id])
  coupon Coupon? @relation(fields: [couponId], references: [id])
}

enum BookingType {
  NIGHTLY
  WEEKLY
  MONTHLY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKEDIN
  CHECKEDOUT
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

// ─────────────────────────────────────────────
// REVIEW
// ─────────────────────────────────────────────

model Review {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  roomId      String   @db.ObjectId
  rating      Int
  commentAr   String?
  commentEn   String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// COUPON
// ─────────────────────────────────────────────

model Coupon {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  code        String   @unique
  discountPct Float
  maxUses     Int
  usedCount   Int      @default(0)
  expiresAt   DateTime
  isActive    Boolean  @default(true)

  bookings Booking[]
}

// ─────────────────────────────────────────────
// OFFER (Seasonal promotions with visuals)
// ─────────────────────────────────────────────

model Offer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  titleAr     String
  titleEn     String
  descAr      String
  descEn      String
  imageUrl    String?
  imagePublicId String?
  discountPct Float
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// FAVORITE ROOM
// ─────────────────────────────────────────────

model FavoriteRoom {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  roomId String @db.ObjectId

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  type      NotifType
  titleAr   String
  titleEn   String
  bodyAr    String
  bodyEn    String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotifType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

// ─────────────────────────────────────────────
// SITE SETTINGS
// ─────────────────────────────────────────────

model SiteSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  slugAr      String    @unique
  slugEn      String    @unique
  titleAr     String
  titleEn     String
  bodyAr      String
  bodyEn      String
  coverImage  String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
